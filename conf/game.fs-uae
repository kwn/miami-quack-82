hard_drive_0_label = Work
hard_drive_0_bootable = 1
floppy_drive_0_sounds = off
chip_memory = 512
fast_memory = 0
window_width = 1116
window_height = 860
joystick_port_0 = mouse
joystick_port_1 = nothing
